# ==============================================
# HireByte Backend - Environment Variables
# ==============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env with real keys to version control.

# OpenAI API Key (required for interview AI)
OPENAI_API_KEY=

# Supabase (optional - for database persistence)
SUPABASE_URL=
SUPABASE_KEY=

# CORS allowed origins (comma-separated, for production)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Rate limiting (requests per minute for general API)
RATE_LIMIT_PER_MINUTE=60
